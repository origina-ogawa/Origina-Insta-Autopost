# このファイルを .env にコピーして値を埋める(.env はコミットされません)

# --- 文章生成 (Google AI Studio で無料取得: https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- ブランド切り替え (own = 自社 / agency = 代行) ---
BRAND=own

# --- Instagram (Meta for Developers で取得) ---
# IG_USER_ID: InstagramビジネスアカウントのID。
#   「Instagramログインによる API設定」の画面に出るIDではなく、
#   https://graph.instagram.com/v23.0/me?access_token=... で返る id を使うこと(値が異なる場合がある)
# IG_ACCESS_TOKEN: アクセストークン(IGAAで始まる。graph.instagram.com 用)
IG_USER_ID=
IG_ACCESS_TOKEN=
GRAPH_API_VERSION=v23.0

# --- 画像の公開URLベース(通常はGitHub Actionsが自動設定。ローカル手動テスト時のみ) ---
IMAGE_BASE_URL=

# --- Chatwork通知(任意。未設定ならスキップ) ---
CHATWORK_API_TOKEN=
CHATWORK_ROOM_ID=
